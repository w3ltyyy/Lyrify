    "mnix2to9-rcwlwf85": {
      "id": "mnix2to9-rcwlwf85",
      "trackKey": "VILLIAN - Случайно Наступил На Шприц:94",
      "lines": [
        {
          "text": "Как называется эта песня?",
          "startTime": 47
        },
        {
          "text": "Это было недолго",
          "startTime": 1207
        },
        {
          "text": "И мой звучок ебашит по колонкам",
          "startTime": 2623
        },
        {
          "text": "Скажи, насколько сильно ты меня любишь (Ха, ага-ага)",
          "startTime": 5364
        },
        {
          "text": "Ха",
          "startTime": 10603
        },
        {
          "text": "Случайно наступил на шприц (Фак)",
          "startTime": 11380
        },
        {
          "text": "Это было недолго (Это не долго)",
          "startTime": 13336
        },
        {
          "text": "И мой звучок ебашит по колонкам",
          "startTime": 15536
        },
        {
          "text": "Скажи, насколько сильно ты меня любишь (Насколько)",
          "startTime": 18287
        },
        {
          "text": "Настолько, что хочешь ребёнка (Ребёнка)",
          "startTime": 21038
        },
        {
          "text": "Блять, да я сам ещё ребёнок (А)",
          "startTime": 24436
        },
        {
          "text": "Новая хуйня на мне – я знаю viral talk, блять (Я знаю)",
          "startTime": 26336
        },
        {
          "text": "И моя моя мама знала, что из меня будет прок, блять (Всё знала)",
          "startTime": 29680
        },
        {
          "text": "Я не могу молчать, мне нужно сказать им хоть слово (Я не могу)",
          "startTime": 32803
        },
        {
          "text": "И даже если ты отдашь всё",
          "startTime": 36198
        },
        {
          "text": "То всё равно останешься всё так же нам должен (Ха)",
          "startTime": 37824
        },
        {
          "text": "И слёзы на щеках молчат, но у меня под кожей (Под кожей)",
          "startTime": 40940
        },
        {
          "text": "И эти пятна говорят о том, что я тебе уже давно не нужен (Не нужен)",
          "startTime": 44607
        },
        {
          "text": "Скажи мне, кому ты должен?",
          "startTime": 50506
        },
        {
          "text": "Ведь я могу закрыть вопрос любыми, блять, вещами",
          "startTime": 52056
        },
        {
          "text": "И мои бабки на счетах говорят то, что я вещаю этим людям",
          "startTime": 55074
        },
        {
          "text": "Я знаю, почему всё, блять, так будет",
          "startTime": 59611
        },
        {
          "text": "И я работаю на сцене, вижу блики, на мне ща блики",
          "startTime": 62873
        },
        {
          "text": "Она всё также курит стики, всё также стики",
          "startTime": 66401
        },
        {
          "text": "Меняю города так часто, но Москва в душе запала",
          "startTime": 69556
        },
        {
          "text": "Я могу нагревать, но всё равно остаться с планом",
          "startTime": 73090
        },
        {
          "text": "Я курю очень много, мне не хватит килограмма (Не хватит)",
          "startTime": 76540
        },
        {
          "text": "Хочет меня, и ей не важно",
          "startTime": 79777
        },
        {
          "text": "Что у меня на руке пентаграмма (Не важно, не важно)",
          "startTime": 82191
        }
